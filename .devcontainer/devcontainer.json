{
  "name": "Android Development",
  "image": "mcr.microsoft.com/devcontainers/java:1-17",
  "postCreateCommand": "bash .devcontainer/setup-android.sh",
  "remoteUser": "vscode",
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  }
}